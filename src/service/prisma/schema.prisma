generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id Int @id @default(autoincrement())
  firstName String
  lastName String 
  phoneNumber String @unique
  email String @unique
  hashedPassword    String
}

model User {
  id Int @id @default(autoincrement())
  fullName String
  email String @unique
  hashedPassword String
}
