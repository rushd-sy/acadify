{
  "name": "Acadify",
  "version": "1.0.0",
  "private": true,
  "description": "Acadify is a platform for managing and tracking students' academic progress through reports, tests, and analytics.",
  "scripts": {
    "dev": "pnpm -r run start:dev",
    "build": "pnpm -r run build",
    "start": "pnpm -r run start",
    "lint": "pnpm -r run lint",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "keywords": [
    "education",
    "analytics",
    "monorepo",
    "nestjs",
    "react"
  ],
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "prettier": "^3.4.2"
  }
}
